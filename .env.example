# ── База данных ──────────────────────────────────────────────
POSTGRES_USER=mlkd
POSTGRES_PASSWORD=mlkd
POSTGRES_DB=mlkd

# ── Payload CMS ──────────────────────────────────────────────
# Длинная случайная строка: openssl rand -hex 32
PAYLOAD_SECRET=change-me-long-random-string
# API-ключ сервисного пользователя (создать в админке: users → service → enable API key)
PAYLOAD_API_KEY=

# ── LLM (litellm-формат "провайдер/модель") ──────────────────
# Лучший бесплатный вариант: Groq (ключ на https://console.groq.com). Необязателен —
# поиск и эмбеддинги работают без ключа; ключ нужен только для чата и саммари.
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Эмбеддинги / OpenAlex ────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# cpu (по умолчанию, стабильно) | mps | cuda
EMBEDDING_DEVICE=cpu
OPENALEX_MAILTO=your-team-email@tecnico.ulisboa.pt

# Токен мутирующих эндпоинтов AI-сервиса (/generate/*, /ingest/*): openssl rand -hex 32
AI_SERVICE_TOKEN=

# Absolute upload dir for the standalone prod server / Docker volume (dev uses <cwd>/media)
MEDIA_DIR=

# ── Деплой (см. docs/DEPLOY.md) ──────────────────────────────
# Vercel Blob — персистентное хранилище медиа на Vercel (локально не задавать = диск)
# BLOB_READ_WRITE_TOKEN=
# Принудительный dev-push схемы Payload (по умолчанию выкл; схема — из миграций/seed)
# PAYLOAD_DB_PUSH=true
