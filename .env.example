# ── База данных ──────────────────────────────────────────────
POSTGRES_USER=mlkd
POSTGRES_PASSWORD=mlkd
POSTGRES_DB=mlkd

# ── Payload CMS ──────────────────────────────────────────────
# Длинная случайная строка: openssl rand -hex 32
PAYLOAD_SECRET=change-me-long-random-string
# API-ключ сервисного пользователя (создать в админке: users → service → enable API key)
PAYLOAD_API_KEY=

# ── LLM (litellm-формат "провайдер/модель") ──────────────────
LLM_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Эмбеддинги / OpenAlex ────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENALEX_MAILTO=your-team-email@tecnico.ulisboa.pt

# Токен мутирующих эндпоинтов AI-сервиса (/generate/*): openssl rand -hex 32
AI_SERVICE_TOKEN=
