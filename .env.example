# Database
POSTGRES_USER=mlkd
POSTGRES_PASSWORD=mlkd
POSTGRES_DB=mlkd

# Payload CMS
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=change-me-long-random-string
# Service user API key from Payload admin: users -> service -> enable API key.
PAYLOAD_API_KEY=

# Server-side LLM configuration.
# Search and embeddings work without these keys; chat, RAG, summaries and snippets
# need at least one configured provider.
LLM_PROVIDER=auto
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200
LLM_FALLBACK_ENABLED=true
LLM_FALLBACK_PROVIDERS=gemini,openrouter,ollama

# Gemini first provider. GOOGLE_API_KEY is accepted as a compatibility alias.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite

# OpenRouter fallback. Free models and quotas can change.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=MLKD Intelligent Research Platform

# Optional local fallback for development only.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Optional paid provider; not used unless added to LLM_FALLBACK_PROVIDERS.
OPENAI_API_KEY=
OPENAI_MODEL=

# Embeddings / OpenAlex
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
OPENALEX_MAILTO=your-team-email@tecnico.ulisboa.pt

# Token for mutating AI service endpoints (/generate/*, /ingest/*).
# Generate with: openssl rand -hex 32
AI_SERVICE_TOKEN=

# Admin RAG. Keep disabled until the supervisor validates the feature.
RAG_ENABLED=false
RAG_MAX_SOURCES=8
RAG_MAX_QUESTION_CHARS=500
RAG_MAX_CONTEXT_CHARS=12000
RAG_TIMEOUT_SECONDS=60
RAG_MIN_EVIDENCE_SOURCES=2
RAG_MIN_SOURCE_SCORE=0.05
RAG_MIN_SEMANTIC_SCORE=0.25

# Absolute upload dir for the standalone prod server / Docker volume.
# Dev uses <cwd>/media.
MEDIA_DIR=

# Deploy (see docs/DEPLOY.md)
# Vercel Blob persistent media storage.
# BLOB_READ_WRITE_TOKEN=
# Force Payload dev schema push. Default is off; production should use migrations.
# PAYLOAD_DB_PUSH=true
